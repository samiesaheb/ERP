{
  "db_name": "PostgreSQL",
  "query": "SELECT i.id, i.item_id,\n                  it.code AS item_code,\n                  it.description AS item_description,\n                  i.qty_on_hand, i.qty_reserved,\n                  COALESCE(i.qty_available, 0) AS \"qty_available!: Decimal\",\n                  i.updated_at\n           FROM inventory i\n           JOIN items it ON it.id = i.item_id\n           ORDER BY it.code",
